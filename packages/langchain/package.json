{
  "name": "@belay/langchain",
  "version": "0.6.1",
  "description": "Belay reliability adapter for LangChain JS & LangGraph: exactly-once tool execution, durable ledger, budgets, rate limits, and human approval gates.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "tsx test/langchain.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "belay",
    "langchain",
    "langgraph",
    "langchainjs",
    "agents",
    "tools",
    "idempotency",
    "reliability",
    "human-in-the-loop",
    "approvals"
  ],
  "license": "MIT",
  "dependencies": {
    "belay": "workspace:*"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.2.0",
    "@langchain/langgraph": ">=0.2.0"
  },
  "peerDependenciesMeta": {
    "@langchain/core": {
      "optional": true
    },
    "@langchain/langgraph": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
